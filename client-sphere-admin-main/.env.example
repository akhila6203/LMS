# Backend API (must match backend PORT, default 5000)
VITE_API_URL=http://localhost:5000/api

# Google OAuth — Web client ID from Google Cloud Console.
# MUST be the same value as backend GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# In Google Cloud Console → Credentials → OAuth 2.0 Client (Web application):
# Authorized JavaScript origins (add all you use locally):
#   http://localhost:8080
#   http://127.0.0.1:8080
# Vite dev server runs on port 8080 (see vite.config.js).
